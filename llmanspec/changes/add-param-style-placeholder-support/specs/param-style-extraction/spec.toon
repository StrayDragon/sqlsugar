kind: llman.sdd.delta
ops[4]{op,req_id,title,statement,from,to,name}:
  add_requirement,"R-J2E-021",named 风格提取,系统 MUST 提取 named 风格参数占位符(:param 格式),null,null,null
  add_requirement,"R-J2E-022",numeric 风格提取,系统 MUST 提取 numeric 风格参数占位符(:1 :2 格式),null,null,null
  add_requirement,"R-J2E-023",pyformat 风格提取,系统 MUST 提取 pyformat 风格参数占位符(%(param)s 格式),null,null,null
  add_requirement,"R-J2E-024",asyncpg 风格提取,系统 MUST 提取 asyncpg 风格参数占位符($1 $2 格式),null,null,null
op_scenarios[4]{req_id,id,given,when,then}:
  "R-J2E-021",S001,SQL 包含 :user_id 和 :name 占位符,系统执行 named 分析器,提取出 user_id 和 name 参数
  "R-J2E-022",S001,SQL 包含 :1 和 :2 占位符,系统执行 numeric 分析器,提取出位置参数 1 和 2
  "R-J2E-023",S001,SQL 包含 %(user_id)s 和 %(name)s 占位符,系统执行 pyformat 分析器,提取出 user_id 和 name 参数
  "R-J2E-024",S001,SQL 包含 $1 和 $2 占位符,系统执行 asyncpg 分析器,提取出位置参数 1 和 2