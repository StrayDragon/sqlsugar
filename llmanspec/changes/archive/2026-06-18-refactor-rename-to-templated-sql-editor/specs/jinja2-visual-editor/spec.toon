kind: llman.sdd.delta
ops[1]{op,req_id,title,statement,from,to,name}:
  add_requirement,"R-J2E-018","编辑器实体命名(Templated SQL Editor)","系统 MUST 将可视化编辑器产品实体统一命名为 Templated SQL Editor 并贯穿命令 ID、配置键、视图类型、UI 标题与组件标识符，与底层 Jinja2 或 Nunjucks 模板引擎命名解耦",null,null,null
op_scenarios[1]{req_id,id,given,when,then}:
  "R-J2E-018",naming,"代码库与 package.json","审查编辑器实体的命令 ID、配置键、视图类型、UI 标题与组件标识符","产品实体统一为 Templated SQL Editor 且不再出现 copyJinja2Template、v2Editor、jinja2-editor-v2、jinja2EditorV2、EditorV2 等旧实体名"
